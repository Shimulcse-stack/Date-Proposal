rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /memories/{memoryId} {
      allow read, write: if true;
    }
    match /responses/{responseId} {
      allow read, write: if true;
    }
    match /stats/{statId} {
      allow read, write: if true;
    }
  }
}
